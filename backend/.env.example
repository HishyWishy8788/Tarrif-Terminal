# --- Auth (optional in dev — leave blank to bypass JWT verification) ---
# Get CLERK_JWKS_URL from https://dashboard.clerk.com → API Keys → Show JWT public key → JWKS URL.
# CLERK_ISSUER is the same domain root (e.g. https://your-app.clerk.accounts.dev).
# CLERK_AUDIENCE is your application's JWT audience claim — when set, audience is enforced.
# CLERK_ADMIN_CLAIM is the JWT claim name that grants admin access (default: "admin").
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
CLERK_ADMIN_CLAIM=admin

# --- CORS allowlist (comma-separated). Wildcards are rejected. ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Admin endpoints ---
# Body must include {"seedKey": "<this>"} AND, when AUTH is enabled, the JWT
# must carry an admin claim. seedKey alone is NOT sufficient with auth on.
TARIFF_SEED_KEY=demo-seed

# --- LLM ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma:latest
OLLAMA_TIMEOUT=60
