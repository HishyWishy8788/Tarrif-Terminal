# Get these from https://dashboard.clerk.com after creating an app.
# Leave blank or unset to run the dashboard WITHOUT auth (Phase 1 behavior).
# Copy this file to `.env.local` and fill in your real values.

VITE_CLERK_PUBLISHABLE_KEY=

# Admin seedKey shipped with the bundle — must match backend TARIFF_SEED_KEY.
# This is NOT a real secret (anyone using devtools can read it). Real auth for
# /api/admin/* is the Clerk admin claim check in backend/auth.py.
VITE_ADMIN_SEED_KEY=demo-seed
